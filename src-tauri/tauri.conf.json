{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Affordable Housing Locator",
  "version": "0.3.0",
  "identifier": "gov.sanjose.housing-locator",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Affordable Housing Locator",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' blob: data: https://*.openfreemap.org https://*.openstreetmap.org; connect-src https://*.openfreemap.org https://*.arcgis.com https://nominatim.openstreetmap.org; font-src 'self' data:; worker-src blob:; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
